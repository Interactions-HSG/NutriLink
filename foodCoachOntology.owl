                                                       foodcoach:AllergenMollusc
                                                       foodcoach:AllergenMustard
                                                       foodcoach:AllergenPeanut
                                                       foodcoach:AllergenSesameSeed
                                                       foodcoach:AllergenSoy
                                                       foodcoach:AllergenSulphite
                                                       foodcoach:AllergenTreeNut
                                                     )
                                         ] .


