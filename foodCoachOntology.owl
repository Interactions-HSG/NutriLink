@base <https://interactions.ics.unisg.ch/foodcoach#> .

<https://interactions.ics.unisg.ch/foodcoach#> rdf:type owl:Ontology ;
                                                rdfs:comment "This is an ontology for FoodCoach project." .

#################################################################
#    Object Properties
#################################################################

###  https://interactions.ics.unisg.ch/foodcoach#abstainsfrom
foodcoach:abstainsfrom rdf:type owl:ObjectProperty ;
                       rdfs:domain foodcoach:user ;
                       rdfs:range foodcoach:abstention .


###  https://interactions.ics.unisg.ch/foodcoach#belongsto
foodcoach:belongsto rdf:type owl:ObjectProperty ;
                    rdfs:domain foodcoach:Product ;
                    rdfs:range foodcoach:minorCategory .


