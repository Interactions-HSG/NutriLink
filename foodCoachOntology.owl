###  https://interactions.ics.unisg.ch/foodcoach#Abstention
foodcoach:Abstention rdf:type owl:Class ;
                     owl:equivalentClass [ rdf:type owl:Class ;
                                           owl:oneOf ( foodcoach:AbstentionMeat
                                                       foodcoach:AllergenCellery
                                                       foodcoach:AllergenCrustacean
                                                       foodcoach:AllergenEgg
                                                       foodcoach:AllergenFish
                                                       foodcoach:AllergenGluten
                                                       foodcoach:AllergenLupin
