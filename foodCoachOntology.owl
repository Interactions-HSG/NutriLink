@prefix : <https://interactions.ics.unisg.ch/foodcoach#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix foodcoach: <https://interactions.ics.unisg.ch/foodcoach#> .
@base <https://interactions.ics.unisg.ch/foodcoach#> .

<https://interactions.ics.unisg.ch/foodcoach#> rdf:type owl:Ontology ;
                                                owl:imports <http://qudt.org/2.1/schema/datatype> ,
                                                            <http://qudt.org/2.1/schema/extensions/functions> ,
                                                            <http://qudt.org/2.1/schema/extensions/imports> ,
                                                            <http://qudt.org/2.1/schema/extensions/skos> ,
                                                            <http://qudt.org/2.1/vocab/unit> ;
                                                rdfs:comment "This is an ontology for FoodCoach project." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/language
<http://purl.org/dc/elements/1.1/language> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/publisher
<http://purl.org/dc/elements/1.1/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/source
<http://purl.org/dc/elements/1.1/source> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/type
<http://purl.org/dc/elements/1.1/type> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/hasVersion
<http://purl.org/dc/terms/hasVersion> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/isReferencedBy
<http://purl.org/dc/terms/isReferencedBy> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/requires
<http://purl.org/dc/terms/requires> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://qudt.org/schema/qudt/unit
<http://qudt.org/schema/qudt/unit> rdf:type owl:AnnotationProperty ;
                                   rdfs:domain <http://qudt.org/schema/qudt/QuantityValue> .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty .


###  https://interactions.ics.unisg.ch/foodcoach#name
foodcoach:name rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf <http://purl.org/dc/terms/title> .


#################################################################
#    Object Properties
#################################################################

###  http://qudt.org/schema/qudt/hasQuantityKind
<http://qudt.org/schema/qudt/hasQuantityKind> rdf:type owl:ObjectProperty ;
                                              rdfs:domain foodcoach:BasketAggInfo ,
                                                          foodcoach:Item ,
                                                          foodcoach:Product ;
                                              rdfs:range <http://qudt.org/schema/qudt/Unit> .


###  http://qudt.org/schema/qudt/quantityValue
<http://qudt.org/schema/qudt/quantityValue> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <http://qudt.org/schema/qudt/Quantity> ;
                                            rdfs:range <http://qudt.org/schema/qudt/QuantityValue> .


###  https://interactions.ics.unisg.ch/foodcoach#abstainsFrom
foodcoach:abstainsFrom rdf:type owl:ObjectProperty ;
                       rdfs:domain foodcoach:User ;
                       rdfs:range foodcoach:Abstention .


###  https://interactions.ics.unisg.ch/foodcoach#belongsToRetailer
foodcoach:belongsToRetailer rdf:type owl:ObjectProperty ;
                            rdfs:domain foodcoach:Office ;
                            rdfs:range foodcoach:Retailer .


###  https://interactions.ics.unisg.ch/foodcoach#buysBasket
foodcoach:buysBasket rdf:type owl:ObjectProperty ;
                     rdfs:domain foodcoach:User ;
                     rdfs:range foodcoach:Basket .


###  https://interactions.ics.unisg.ch/foodcoach#containsAllergen
foodcoach:containsAllergen rdf:type owl:ObjectProperty ;
                           rdfs:domain foodcoach:Product ;
                           rdfs:range foodcoach:Allergen .


###  https://interactions.ics.unisg.ch/foodcoach#containsInformationOfBasket
foodcoach:containsInformationOfBasket rdf:type owl:ObjectProperty ;
                                      rdfs:domain foodcoach:BasketAggInfo ;
                                      rdfs:range foodcoach:Basket .


###  https://interactions.ics.unisg.ch/foodcoach#containsItem
foodcoach:containsItem rdf:type owl:ObjectProperty ;
                       rdfs:domain foodcoach:Basket ;
                       rdfs:range foodcoach:Item .


###  https://interactions.ics.unisg.ch/foodcoach#containsNutritionInformation
foodcoach:containsNutritionInformation rdf:type owl:ObjectProperty ;
                                       rdfs:domain foodcoach:Product ;
                                       rdfs:range foodcoach:NutritionInformation .


###  https://interactions.ics.unisg.ch/foodcoach#distributesItem
foodcoach:distributesItem rdf:type owl:ObjectProperty ;
                          rdfs:domain foodcoach:Retailer ;
                          rdfs:range foodcoach:Item .


###  https://interactions.ics.unisg.ch/foodcoach#hasImage
foodcoach:hasImage rdf:type owl:ObjectProperty ;
                   rdfs:domain foodcoach:MinorCategory ,
                               foodcoach:Product ;
                   rdfs:range <http://purl.org/dc/dcmitype/Image> .


###  https://interactions.ics.unisg.ch/foodcoach#isAllergicTo
foodcoach:isAllergicTo rdf:type owl:ObjectProperty ;
                       rdfs:domain foodcoach:User ;
                       rdfs:range foodcoach:Allergen .


###  https://interactions.ics.unisg.ch/foodcoach#isAtGeoLoc
foodcoach:isAtGeoLoc rdf:type owl:ObjectProperty ;
                     rdfs:domain foodcoach:Office ;
                     rdfs:range foodcoach:OfficeGeoLoc .


###  https://interactions.ics.unisg.ch/foodcoach#isAvailableIn
foodcoach:isAvailableIn rdf:type owl:ObjectProperty ;
                        rdfs:domain foodcoach:Product ;
                        rdfs:range foodcoach:MarketRegion .


###  https://interactions.ics.unisg.ch/foodcoach#isFromOffice
foodcoach:isFromOffice rdf:type owl:ObjectProperty ;
                       rdfs:domain foodcoach:Basket ;
                       rdfs:range foodcoach:Office .


###  https://interactions.ics.unisg.ch/foodcoach#isInfluencedByDisorder
foodcoach:isInfluencedByDisorder rdf:type owl:ObjectProperty ;
                                 rdfs:domain foodcoach:User ;
                                 rdfs:range foodcoach:Disorder .


###  https://interactions.ics.unisg.ch/foodcoach#isOfMajorCategory
foodcoach:isOfMajorCategory rdf:type owl:ObjectProperty ;
                            rdfs:domain foodcoach:MinorCategory ;
                            rdfs:range foodcoach:MajorCategory .


###  https://interactions.ics.unisg.ch/foodcoach#isOfMinorCategory
foodcoach:isOfMinorCategory rdf:type owl:ObjectProperty ;
                            rdfs:domain foodcoach:Product ;
                            rdfs:range foodcoach:MinorCategory .


###  https://interactions.ics.unisg.ch/foodcoach#isOfQuantityValue
foodcoach:isOfQuantityValue rdf:type owl:ObjectProperty ;
                            rdfs:domain foodcoach:BasketAggInfo ,
                                        foodcoach:Item ,
                                        foodcoach:Nutrient ,
                                        foodcoach:Product ;
                            rdfs:range <http://qudt.org/schema/qudt/QuantityValue> .


###  https://interactions.ics.unisg.ch/foodcoach#isOfUser
foodcoach:isOfUser rdf:type owl:ObjectProperty ;
                   rdfs:domain foodcoach:PiiData ;
                   rdfs:range foodcoach:User .


###  https://interactions.ics.unisg.ch/foodcoach#isProducedBy
foodcoach:isProducedBy rdf:type owl:ObjectProperty ;
                       rdfs:domain foodcoach:Product ;
                       rdfs:range foodcoach:Producer .


###  https://interactions.ics.unisg.ch/foodcoach#isRegisteredIn
foodcoach:isRegisteredIn rdf:type owl:ObjectProperty ;
                         rdfs:domain foodcoach:User ;
                         rdfs:range foodcoach:Project .


###  https://interactions.ics.unisg.ch/foodcoach#matches
foodcoach:matches rdf:type owl:ObjectProperty ,
                           owl:SymmetricProperty ;
                  rdfs:domain foodcoach:Item ;
                  rdfs:range foodcoach:Product .


###  https://interactions.ics.unisg.ch/foodcoach#mayContainAllergen
foodcoach:mayContainAllergen rdf:type owl:ObjectProperty ;
                             rdfs:domain foodcoach:Product ;
                             rdfs:range foodcoach:Allergen .


#################################################################
#    Data properties
#################################################################

###  http://qudt.org/schema/qudt/id
<http://qudt.org/schema/qudt/id> rdf:type owl:DatatypeProperty ;
                                 rdfs:domain foodcoach:MajorCategory ,
                                             foodcoach:MinorCategory ,
                                             foodcoach:Product ,
                                             foodcoach:Project ,
                                             foodcoach:User ;
                                 rdfs:range xsd:int ,
                                            xsd:string ;
                                 rdfs:comment """The id of Product, MinorCategory and MajorCategory should be of type int.
The id of User and Project should be of type string."""@en .


###  http://www.linkedmodel.org/schema/vaem#name
<http://www.linkedmodel.org/schema/vaem#name> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain foodcoach:Item ,
                                                          foodcoach:MajorCategory ,
                                                          foodcoach:MinorCategory ,
                                                          foodcoach:Nutrient ,
                                                          foodcoach:Office ,
                                                          foodcoach:Producer ,
                                                          foodcoach:Product ,
                                                          foodcoach:Project ;
                                              rdfs:range xsd:string ;
                                              foodcoach:name ""@de ,
                                                             ""@en ,
                                                             ""@fr ,
                                                             ""@it .


